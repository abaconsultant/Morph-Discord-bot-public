# ── Required ──────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
OWNER_ID=your_discord_user_id_here

# ── Database (Supabase) ───────────────────
# Transaction pooler URL จาก Supabase → Settings → Database → Connection string
SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── API (optional) ────────────────────────
# ถ้าไม่ได้ใช้ REST API ไม่ต้องตั้ง
API_SECRET=
API_PORT=8000
API_CORS_ORIGINS=*
